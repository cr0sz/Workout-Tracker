rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny: No one can access any document by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Per-user data isolation:
    // Only authenticated users can access documents within their own UID folder.
    // This covers subcollections like workouts, exercises, sets, etc.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
